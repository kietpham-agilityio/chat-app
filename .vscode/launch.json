{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Debug",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["--dart-define-from-file", ".env"]
    },
    {
      "name": "Run Profile",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "args": ["--dart-define-from-file", ".env"]
    },
    {
      "name": "Run Release",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "args": ["--dart-define-from-file", ".env"]
    }
  ]
}
